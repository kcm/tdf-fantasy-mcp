{
  "name": "tdf-fantasy-mcp",
  "version": "0.0.2",
  "description": "MCP server for the Tour de France Fantasy game (fantasy.letour.fr)",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/index.ts",
    "start": "node dist/index.js",
    "test": "npm run build && node --test dist/__tests__/scoring.test.js dist/__tests__/optimization.test.js",
    "prepublishOnly": "npm run build"
  },
  "bin": {
    "tdf-fantasy": "dist/index.js"
  },
  "keywords": [
    "mcp",
    "tour-de-france",
    "fantasy",
    "cycling"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.8.0",
    "ts-node": "^10.9.0",
    "typescript": "^6.0.3"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
